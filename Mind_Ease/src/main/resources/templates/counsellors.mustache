<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Counsellors</title>
</head>
<body>
<h1>Counsellor List</h1>

<table style="border-collapse: collapse; width: 100%;">
    <tr>
        <th style="border:1px solid black; padding:5px;">ID</th>
        <th style="border:1px solid black; padding:5px;">Name</th>
        <th style="border:1px solid black; padding:5px;">Specialization</th>
        <th style="border:1px solid black; padding:5px;">Email</th>
        <th style="border:1px solid black; padding:5px;">Availability</th>
    </tr>
    {{#counsellors}}
        <tr>
            <td style="border:1px solid black; padding:5px;">{{id}}</td>
            <td style="border:1px solid black; padding:5px;">{{name}}</td>
            <td style="border:1px solid black; padding:5px;">{{specialization}}</td>
            <td style="border:1px solid black; padding:5px;">{{email}}</td>
            <td style="border:1px solid black; padding:5px;">{{availability}}</td>
        </tr>
    {{/counsellors}}
</table>

<br>
<a href="/counsellors/add">Add New Counsellor</a> |
<a href="/">Back to Home</a>
</body>
</html>