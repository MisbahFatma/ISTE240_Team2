<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Add Counsellor</title>
</head>
<body>
<h1>Add Counsellor</h1>

<form action="/counsellors/add" method="post">
    <label for="id">ID:</label>
    <input type="number" id="id" name="id" required><br><br>

    <label for="name">Name:</label>
    <input type="text" id="name" name="name" required><br><br>

    <label for="specialization">Specialization:</label>
    <input type="text" id="specialization" name="specialization" required><br><br>

    <label for="email">Email:</label>
    <input type="email" id="email" name="email" required><br><br>

    <label for="availability">Availability:</label>
    <input type="text" id="availability" name="availability" required><br><br>

    <button type="submit">Add Counsellor</button>
</form>

<br>
<a href="/counsellors">View Counsellors</a> |
<a href="/">Back to Home</a>
</body>
</html>