<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Add Stress Survey</title>
</head>
<body>
<h1>Add Stress Survey</h1>

<form action="/surveys/add" method="post">
    <label for="student">Student:</label>
    <select id="student" name="studentId" required>
        {{#students}}
        <option value="{{id}}">{{name}}</option>
        {{/students}}
    </select><br><br>

    <label for="stressLevel">Stress Level (1-5):</label>
    <input type="number" id="stressLevel" name="stressLevel" min="1" max="5" required><br><br>

    <label for="date">Date:</label>
    <input type="date" id="date" name="date" required><br><br>

    <button type="submit">Add Survey</button>
</form>

<br>
<a href="/surveys">View Surveys</a> |
<a href="/">Back to Home</a>
</body>
</html>